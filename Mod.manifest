[mod_information]

name="Hev's More Minerals"
id="hev.MoreMinerals"
description="MOREMINERALS_MOD_DESCRIPTION"
brief="MOREMINERALS_MOD_BRIEF"
author="__hev"
credits=["   --- Contributors ---   ","Tyelan Sin - original mod request","Za'krin - original mod this is built off of","Hedrauta - German translations","   --- Supporters ---   ","GAZI - supporter (ko-fi)","Bagger dude - supporter (ko-fi)","WT - supporter (ko-fi)"]

[version]

version_major=1
version_minor=4
version_bugfix=4
version_metadata=""

[configs]

MOREMINERALS_SECTION_ORE_HANDLING={
	"cargo_behaviour":{
		"name":"MOREMINERALS_CONFIG_CARGO_BEHAVIOUR",
		"description":"MOREMINERALS_CONFIG_CARGO_BEHAVIOUR_TOOLTIP",
		"type":"option",
		"store_method":"string",
		"options":["MOREMINERALS_CARGO_BEHAVIOUR_LIMITED", "MOREMINERALS_CARGO_BEHAVIOUR_DEFAULT", "MOREMINERALS_CARGO_BEHAVIOUR_REDUCED", "MOREMINERALS_CARGO_BEHAVIOUR_DYNAMIC"],
		"default":"MOREMINERALS_CARGO_BEHAVIOUR_LIMITED",
	},
	"max_cargo_types":{
		"name":"MOREMINERALS_CARGO_BEHAVIOUR_MAX_TYPES",
		"description":"MOREMINERALS_CARGO_BEHAVIOUR_MAX_TYPES_TOOLTIP",
		"type":"int",
        "style":"slider",
        "min":6,
        "max":50,
        "step":1,
		"default":6,
	},
	"eject_processed_ore":{
		"name":"MOREMINERALS_CONFIG_EJECT_PROCESSED_ORE",
		"description":"MOREMINERALS_CONFIG_EJECT_PROCESSED_ORE_TOOLTIP",
		"type":"bool",
		"default":true
	},
	"eject_processed_ore_reset_filters":{
		"name":"MOREMINERALS_CONFIG_EJECT_PROCESSED_ORE_RESET_FILTERS",
		"description":"MOREMINERALS_CONFIG_EJECT_PROCESSED_ORE_RESET_FILTERS_TOOLTIP",
		"type":"bool",
		"default":false,
		"requires_bools":["Hev'sMoreMinerals/MOREMINERALS_SECTION_ORE_HANDLING/eject_processed_ore"],
	},
}
MOREMINERALS_SECTION_MINERALS={
	"legacy_mineral_names":{
		"name":"MOREMINERALS_CONFIG_LEGACY_MINERAL_NAMES",
		"description":"MOREMINERALS_CONFIG_LEGACY_MINERAL_NAMES_TOOLTIP",
		"type":"bool",
		"default":false
	},
}


[tags]

TAG_ALLOW_ACHIEVEMENTS={"type":"bool","value":true}
TAG_OVERHAUL={"type":"bool","value":true}
TAG_QOL={"type":"bool","value":true}
TAG_ADDS_GAMEPLAY_MECHANICS={"type":"array","value":["Adds lots of new minerals"]}
TAG_ADD_TRANSIT_TIPS={"type":"array","value":["MOREMINERALS_TRANSIT_TIPS_1","MOREMINERALS_TRANSIT_TIPS_2"]}

[languages]

en="100%"
de="100%"

